# Copy this file to .env and fill in your values.
# TaskForge reads these at startup via pydantic-settings.

# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL of your local Ollama instance.
OLLAMA_ENDPOINT=http://localhost:11434

# Model to use for planning and synthesis. Must be pulled first:
#   ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Timeout (seconds) for a single Ollama HTTP call.
OLLAMA_TIMEOUT=60

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Maximum number of tool calls the agent can make per task.
MAX_TOOL_CALLS=10

# Hard timeout (seconds) for the entire agent run (background task).
TASK_TIMEOUT=300

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default) — just a file path.
DATABASE_URL=sqlite:///./taskforge.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/taskforge
